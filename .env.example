# openduo daemon URL (default: http://127.0.0.1:20233)
ALADUO_DAEMON_URL=http://127.0.0.1:20233

# WeChat ilink bot API base URL (default: https://ilinkai.weixin.qq.com)
WECHAT_API_BASE=https://ilinkai.weixin.qq.com

# DM policy: 'open' (accept all) or 'allowlist' (only allowed users)
WECHAT_DM_POLICY=open

# Allowlist: comma-separated WeChat userIds (only used when WECHAT_DM_POLICY=allowlist)
# WECHAT_ALLOW_FROM=userId1,userId2

# Directory for persisting token and sync cursor (default: ~/.openduo/wechat-channel)
# WECHAT_STATE_DIR=~/.openduo/wechat-channel

# Log level: error | warn | info | debug (default: info)
WECHAT_LOG_LEVEL=info
